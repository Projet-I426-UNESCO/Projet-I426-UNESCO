<!doctype html>
<html lang="fr">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profil - </title>
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
        @import url("https://fonts.googleapis.com/css2?family=K2D:wght@300;400;500&display=swap");

        main {
            padding: 25px;
        }

        .info-block {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-gap: 10px;
            grid-auto-rows: minmax(150px, auto);
            max-width: 1500px;
            margin: 0 auto;
            flex-direction: row;
            align-items: flex-start;
            justify-content: space-around;
            justify-items: stretch;
            align-items: stretch;
        }

        .info-block>div {
            background-color: #1e2533;
            border-radius: 20px;
            padding: 20px;
            color: #d1d5db;
        }

        .info-block>div:last-child {
            background-color: #0f172a;
            border-radius: 20px;
            padding: 0px;
            color: #d1d5db;
        }

        /*background-color: #0f172a;*/
        .name-block {
            display: flex;
            align-items: center;
            grid-column: 1 / 3;
            justify-content: space-between;
            background: linear-gradient(90deg, rgba(30, 41, 59, 1) 0%, rgba(15, 23, 42, 1) 100%);
            border: 1px solid #2D313E;
        }

        .name-avatar {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .avatar {
            height: 100px;
            width: 100px;
            border: 4px solid #2D313E;
            border-radius: 50%;
            object-fit: cover;
        }

        .name h2 {
            color: #ffffff;
            font-size: 28px;
            margin: 0;
        }

        .name p {
            color: #94a3b8;
            font-size: 14px;
            margin: 0;
        }

        .last-visit-block {
            grid-column: 3;
            grid-row: 1/4;
        }

        .progress-block {
            grid-column: 1/2;
            grid-row: 2;
        }

        .continent-stats-block {
            grid-column: 2;
            grid-row: 2/4;

        }

        .continent-stats-block .boss {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 5vh;
            text-align: center;
            justify-content: stretch;
        }

        .continent-stats-block>div {
            justify-self: center;
            align-self: center;

        }

        .few-last-visits-block {
            grid-column: 1;
            grid-row: 3/5;
        }

        .general-stats-block {
            grid-column: 2/4;
            grid-row: 4;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            background-color: #ffffff;
            gap: 10px;

        }

        .general-stats-block>div {
            background-color: #1e2533;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #d1d5db;
            font-size: 18px;

        }

        .item {
            width: 60px;
            height: 60px;
            background-color: #68bff8;
            border-radius: 50%;
            align-items: center;
            flex-direction: column;

        }

        .continent-text {
            margin-top: 60px;
            justify-self: center;
        }

        .map-list-block {
            height: 500px;
            background-color: #1e2533;
            max-width: 1500px;
            margin: 0 auto;
            padding-top: 50px;
            border-radius: 20px;
            margin-top: 10px;
        }

        .line {
            display: flex;
            gap: 10px;
        }

        .logout-btn,
        .modif-btn {
            height: 35px;
            width: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: white;
            text-decoration: none;
            font-weight: 500;
        }

        .logout-btn {
            background-color: #F25F61;
        }

        .modif-btn {
            background-color: #5F7EF2;
        }
    </style>
</head>

<body>
    @layout('components/layout/index', { title: 'Accueil' })


    <main>
        <div class="info-block">
            <div class="name-block">
                <div class="name-avatar">
                    <img class="avatar" src="" alt="Avatar" />
                    <div class="name">
                        <h2></h2>
                    </div>
                </div>
                <div class="line">
                    <a href="" class="logout-btn">Se déconnecter</a>
                    <a href="" class="modif-btn">Modifier le compte</a>
                </div>
            </div>

            <div class="last-visit-block">
                <p>Dernière visite</p>
                <p></p>
            </div>

            <div class="progress-block">
                <p>Progression Globale</p>
                <p>%</p>
            </div>

            <div class="continent-stats-block">
                <p>Exploration par continent</p>
                <div class="continent-grid">

                </div>
            </div>

            <div class="few-last-visits-block">
                <p>Visites récentes</p>
            </div>

            <div class="general-stats-block">
                <div class="stat-card">
                    <span>Sites visités</span>

                </div>
                <div class="stat-card">
                    <span>Continents</span>

                </div>
                <div class="stat-card">
                    <span>Taux de complétion</span>

                </div>
                <div class="stat-card">
                    <span>Pays explorés</span>

                </div>
            </div>
        </div>

        <div class="map-list-block">
        </div>
    </main>
</body>
@end

</html>